# CDSS Production Environment Configuration
# Do not place secrets in this file (public client-side config only).

VITE_API_BASE_URL=https://__CDSS_API_HOST__.azurecontainerapps.io/api
VITE_AZURE_CLIENT_ID=__SPA_CLIENT_ID__
VITE_AZURE_TENANT_ID=__TENANT_ID__
VITE_AZURE_AUTHORITY=https://login.microsoftonline.com/__TENANT_ID__
VITE_API_SCOPE=api://cdss-api/access_as_user
VITE_REDIRECT_URI=https://__STATIC_WEB_APP_HOSTNAME__.azurestaticapps.net
VITE_POST_LOGOUT_URI=https://__STATIC_WEB_APP_HOSTNAME__.azurestaticapps.net
VITE_WS_ENDPOINT=wss://__CDSS_PUBSUB_HOST__.webpubsub.azure.com
VITE_ENVIRONMENT=production
VITE_USE_MOCK_API=false
