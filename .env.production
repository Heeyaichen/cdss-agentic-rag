# CDSS Production Environment Configuration
# This file is used by Vite during `npm run build`
# Do NOT put secrets in this file — it is bundled into the client.

# Backend API (Azure Container Apps)
VITE_API_BASE_URL=https://cdss-prod-api.ambitioussky-57644cbd.eastus2.azurecontainerapps.io/api

# Azure Entra ID (SPA App Registration)
VITE_AZURE_CLIENT_ID=b1aff2ac-5269-49bc-888c-336b46ce0585
VITE_AZURE_TENANT_ID=da8ed114-679d-4198-88e5-128a1bbba6c0

# API Scope for backend access
VITE_API_SCOPE=api://ce7cfe60-e995-4fe1-90de-b77fcc507335/access_as_user

# WebSocket endpoint (Azure Web PubSub)
VITE_WS_ENDPOINT=wss://cdss-prod-pubsub.webpubsub.azure.com

# Environment flag
VITE_USE_MOCK_API=false
